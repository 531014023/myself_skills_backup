{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "横纵分析法研究框架",
  "version": "1.0",
  "meta": {
    "研究对象名称": "string",
    "研究对象类型": "产品 | 公司 | 概念 | 人物",
    "所属领域": "string",
    "研究动机": "string",
    "研究时间": "string"
  },
  "纵轴_生命历程": {
    "起源": {
      "诞生背景": "string",
      "创始团队/发起人": "string",
      "早期发展": "string"
    },
    "关键时间节点": [
      {
        "时间": "string",
        "事件": "string",
        "意义": "string"
      }
    ],
    "阶段划分": [
      {
        "阶段名称": "string",
        "时间范围": "string",
        "核心特征": "string"
      }
    ],
    "路径依赖分析": "string",
    "叙事主线": "string"
  },
  "横轴_竞争对比": {
    "竞争格局": "无竞争对手 | 少数竞争 | 充分竞争",
    "竞争对手列表": [
      {
        "名称": "string",
        "类型": "string",
        "核心优势": "string",
        "核心劣势": "string"
      }
    ],
    "多维对比矩阵": {
      "技术维度": "string",
      "用户体验": "string",
      "市场定位": "string",
      "生态建设": "string"
    },
    "市场定位分析": "string"
  },
  "横纵交叉_洞察": {
    "历史决策与当前竞争位置的联系": "string",
    "未来预测": {
      "乐观情景": "string",
      "基准情景": "string",
      "危险情景": "string"
    }
  },
  "输出要求": {
    "纵向叙事": "3000-8000字符",
    "横向对比": "2000-5000字符",
    "交叉洞察": "1000-2000字符"
  }
}
